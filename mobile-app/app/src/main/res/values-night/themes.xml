<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base application theme. -->
    <style name="Base.Theme.BorrowHub" parent="Theme.Material3.DayNight.NoActionBar">
        <item name="colorPrimary">@color/primary_crimson</item>
        <item name="colorPrimaryVariant">@color/primary_crimson_dark</item>
        <item name="colorOnPrimary">@color/gray_50</item>

        <item name="colorSecondary">@color/gray_500</item>
        <item name="colorSecondaryVariant">@color/gray_400</item>
        <item name="colorOnSecondary">@color/gray_50</item>

        <item name="colorSurface">@color/gray_900</item>
        <item name="colorOnSurface">@color/gray_50</item>
        <item name="android:colorBackground">@color/gray_900</item>
        <item name="colorOnBackground">@color/gray_50</item>

        <item name="colorOutlineVariant">@color/gray_700</item>

        <item name="android:statusBarColor">@color/black</item>
        <item name="android:navigationBarColor">@color/gray_900</item>
        <item name="android:windowLightStatusBar">false</item>

        <!-- Improved Dialog UI -->
        <item name="materialAlertDialogTheme">@style/ThemeOverlay.App.MaterialAlertDialog</item>

        <!-- Improved Toolbar and Dropdown UI -->
        <item name="toolbarStyle">@style/Widget.App.Toolbar</item>
        <item name="actionOverflowMenuStyle">@style/Widget.App.OverflowMenu</item>
        <item name="popupMenuStyle">@style/Widget.App.PopupMenu</item>
    </style>

    <style name="ThemeOverlay.App.MaterialAlertDialog" parent="ThemeOverlay.Material3.MaterialAlertDialog">
        <item name="alertDialogStyle">@style/MaterialAlertDialog.App</item>
    </style>

    <style name="MaterialAlertDialog.App" parent="MaterialAlertDialog.Material3">
        <item name="shapeAppearance">@style/ShapeAppearance.App.Dialog</item>
    </style>

    <style name="ShapeAppearance.App.Dialog" parent="ShapeAppearance.Material3.MediumComponent">
        <item name="cornerSize">24dp</item>
    </style>

    <style name="Theme.BorrowHub" parent="Base.Theme.BorrowHub" />

    <style name="Widget.App.BottomNavigationView" parent="Widget.Material3.BottomNavigationView">
        <item name="itemIconTint">@color/bnv_item_color</item>
        <item name="itemTextColor">@color/bnv_item_color</item>
        <item name="itemRippleColor">@color/primary_crimson_transparent</item>
        <item name="labelVisibilityMode">labeled</item>
        <item name="itemIconSize">22dp</item>
    </style>

    <style name="ThemeOverlay.App.BottomNavigationView" parent="">
        <item name="colorSecondaryContainer">@android:color/transparent</item>
        <item name="colorOnSecondaryContainer">@color/primary_crimson</item>
    </style>
</resources>