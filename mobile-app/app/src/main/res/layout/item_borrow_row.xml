<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="12dp"
    app:cardBackgroundColor="@color/gray_100"
    app:cardCornerRadius="16dp"
    app:cardElevation="0dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="12dp">

        <!-- Category / Type dropdown -->
        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/tilItemType"
            style="@style/Widget.Material3.TextInputLayout.OutlinedBox.ExposedDropdownMenu"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="@string/transaction_item_type_label">

            <AutoCompleteTextView
                android:id="@+id/actvItemType"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:focusable="false"
                android:focusableInTouchMode="false"
                android:inputType="none" />
        </com.google.android.material.textfield.TextInputLayout>

        <!-- Specific Item dropdown (filtered by type) -->
        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/tilItemName"
            style="@style/Widget.Material3.TextInputLayout.OutlinedBox.ExposedDropdownMenu"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:hint="@string/transaction_item_name_label">

            <AutoCompleteTextView
                android:id="@+id/actvItemName"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:focusable="false"
                android:focusableInTouchMode="false"
                android:inputType="none" />
        </com.google.android.material.textfield.TextInputLayout>

        <!-- Remove row button (right-aligned, only shown when multiple rows exist) -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnRemoveRow"
            style="@style/Widget.Material3.Button.TextButton"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="end"
            android:layout_marginTop="4dp"
            android:text="@string/transaction_remove_item"
            android:textColor="@color/inventory_status_maintenance_text"
            android:visibility="gone" />

    </LinearLayout>
</com.google.android.material.card.MaterialCardView>
