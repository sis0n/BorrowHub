<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="12dp"
    android:clickable="true"
    android:focusable="true"
    android:foreground="?android:attr/selectableItemBackground"
    app:cardBackgroundColor="@color/gray_100"
    app:cardCornerRadius="16dp"
    app:cardElevation="0dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- Header: Action Tag and Timestamp -->
        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp">

            <TextView
                android:id="@+id/tvLogAction"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_alignParentStart="true"
                android:background="@drawable/bg_status_badge"
                android:paddingHorizontal="8dp"
                android:paddingVertical="4dp"
                android:text="Action"
                android:textColor="?attr/colorOnSurface"
                android:textSize="12sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tvLogTimestamp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_alignParentEnd="true"
                android:layout_centerVertical="true"
                android:text="Mar 20, 2026 09:15 AM"
                android:textColor="?attr/colorOnSurfaceVariant"
                android:textSize="12sp"
                android:textStyle="bold" />
        </RelativeLayout>

        <!-- Primary Text (Bold for Transactions) -->
        <TextView
            android:id="@+id/tvLogPrimary"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Primary Text"
            android:textColor="?attr/colorOnSurface"
            android:textSize="14sp" />

        <!-- Secondary Text (Borrower/Target) -->
        <TextView
            android:id="@+id/tvLogSecondary"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="Secondary Text"
            android:textColor="?attr/colorOnSurfaceVariant"
            android:textSize="13sp" />

        <!-- Tertiary Text (Performed By) -->
        <TextView
            android:id="@+id/tvLogTertiary"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:text="Tertiary Text"
            android:textColor="?attr/colorOnSurfaceVariant"
            android:textSize="13sp" />

        <!-- Quaternary Text (Description for Activity Logs) -->
        <TextView
            android:id="@+id/tvLogQuaternary"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="Quaternary Text"
            android:textColor="?attr/colorOnSurfaceVariant"
            android:textSize="13sp" />

    </LinearLayout>

</com.google.android.material.card.MaterialCardView>
