<?xml version="1.0" encoding="utf-8"?>
<navigation xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/nav_graph"
    app:startDestination="@id/homeFragment">

    <fragment
        android:id="@+id/homeFragment"
        android:name="com.example.borrowhub.view.fragment.HomeFragment"
        android:label="Home"
        tools:layout="@layout/fragment_home" />

    <fragment
        android:id="@+id/inventoryFragment"
        android:name="com.example.borrowhub.view.fragment.InventoryFragment"
        android:label="Inventory"
        tools:layout="@layout/fragment_inventory" />

    <fragment
        android:id="@+id/transactionFragment"
        android:name="com.example.borrowhub.view.fragment.TransactionFragment"
        android:label="Transaction"
        tools:layout="@layout/fragment_transaction">
        <argument
            android:name="initial_tab"
            app:argType="integer"
            android:defaultValue="0" />
    </fragment>

    <fragment
        android:id="@+id/logsFragment"
        android:name="com.example.borrowhub.view.fragment.LogsFragment"
        android:label="Logs"
        tools:layout="@layout/fragment_logs" />

    <fragment
        android:id="@+id/studentManagementFragment"
        android:name="com.example.borrowhub.view.fragment.StudentManagementFragment"
        android:label="Student Management"
        tools:layout="@layout/fragment_student_management" />

    <fragment
        android:id="@+id/accountSettingsFragment"
        android:name="com.example.borrowhub.view.fragment.AccountSettingsFragment"
        android:label="Account Settings"
        tools:layout="@layout/fragment_account_settings" />

    <fragment
        android:id="@+id/userManagementFragment"
        android:name="com.example.borrowhub.view.fragment.UserManagementFragment"
        android:label="User Management"
        tools:layout="@layout/fragment_user_management" />

</navigation>
